# ---------------------------------------------------------------------------
# FitVision AI environment variables
# Copy this file to .env (the Prisma CLI reads .env; Next.js reads it too).
# Put machine-only secret overrides in .env.local if you prefer.
# Never commit real secrets — both .env and .env*.local are gitignored.
# ---------------------------------------------------------------------------

# Database. The Prisma datasource provider is auto-detected from this URL by
# scripts/set-prisma-provider.mjs (no manual schema edits needed):
#   file:./dev.db                -> sqlite   (local dev; creates prisma/dev.db)
#   postgresql://user:pass@host/db?sslmode=require -> postgresql (production)
# In production (Vercel/serverless) use a managed Postgres (Neon/Supabase/Vercel
# Postgres). SQLite does not persist on serverless filesystems.
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# File storage. Local disk by default; Vercel Blob in production.
#   STORAGE_PROVIDER="local"        -> writes to /public/uploads (default)
#   STORAGE_PROVIDER="vercel-blob"  -> uses Vercel Blob (returns public URLs)
# Auto-selects vercel-blob when BLOB_READ_WRITE_TOKEN is set (e.g. after linking
# a Vercel Blob store), so you usually don't need to set STORAGE_PROVIDER.
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER="local"
# BLOB_READ_WRITE_TOKEN=""   # provided automatically by Vercel when a Blob store is linked

# ---------------------------------------------------------------------------
# AI image generation (preview of the product in the room)
# Provider: "mock" (default) | "openai" | "gemini"
#   mock   -> returns the original room photo with an "AI preview placeholder" label
#   openai -> OpenAI Images edit API (default model gpt-image-1)
#   gemini -> Gemini image model (default gemini-2.5-flash-image)
# Falls back to mock automatically if the matching API key is missing.
# ---------------------------------------------------------------------------
IMAGE_GENERATION_PROVIDER="mock"

# ---------------------------------------------------------------------------
# AI vision dimension estimation (guess W/H/D and available space from a photo)
# Provider: "mock" (default) | "openai" | "gemini"
#   mock   -> heuristic estimate from typical category sizes (no API key)
#   openai -> GPT vision (default model gpt-4o-mini)
#   gemini -> Gemini vision (default gemini-2.0-flash)
# Falls back to mock automatically if the matching API key is missing.
# ---------------------------------------------------------------------------
VISION_PROVIDER="mock"

# ---------------------------------------------------------------------------
# API keys + optional model overrides (shared by image gen and vision)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Optional model overrides (sensible defaults are used if unset):
# OPENAI_IMAGE_MODEL="gpt-image-1"
# OPENAI_VISION_MODEL="gpt-4o-mini"
# GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
# GEMINI_VISION_MODEL="gemini-2.0-flash"
