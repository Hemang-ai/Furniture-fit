# ---------------------------------------------------------------------------
# FitVision AI environment variables
# Copy this file to .env (the Prisma CLI reads .env; Next.js reads it too).
# Put machine-only secret overrides in .env.local if you prefer.
# Never commit real secrets — both .env and .env*.local are gitignored.
# ---------------------------------------------------------------------------

# Database (required). The Prisma datasource provider is "postgresql"
# (prisma/schema.prisma). Production MUST set this to a managed Postgres URL.
#
# Production (Postgres) format:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
#
# Local zero-setup SQLite alternative: also set provider = "sqlite" in
# prisma/schema.prisma, then run `npm run db:push`:
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# File storage. Local disk by default; Supabase Storage or Vercel Blob in prod.
#   STORAGE_PROVIDER="local"        -> writes to /public/uploads (default)
#   STORAGE_PROVIDER="supabase"     -> Supabase Storage (public bucket, auto-created)
#   STORAGE_PROVIDER="vercel-blob"  -> Vercel Blob
# Auto-selection (when STORAGE_PROVIDER is unset): Vercel Blob if a Blob token is
# present, else Supabase if the service-role key is present, else local.
# Images are downscaled in the browser before upload, so storage stays small.
# ---------------------------------------------------------------------------
# STORAGE_PROVIDER="supabase"
# SUPABASE_STORAGE_BUCKET="uploads"        # bucket name (auto-created as public)
# Supabase Storage reuses your Supabase project. These are added automatically by
# the Vercel<>Supabase integration; for local dev set them if you want Supabase:
# SUPABASE_URL="https://<ref>.supabase.co"           # or NEXT_PUBLIC_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY=""                        # server-side only — secret
# Vercel Blob (alternative): BLOB_READ_WRITE_TOKEN is added when you link a Blob store
# BLOB_READ_WRITE_TOKEN=""

# ---------------------------------------------------------------------------
# Ephemeral storage cleanup (/api/cleanup). Deletes Blob uploads/previews older
# than BLOB_TTL_MINUTES. Hit it on a schedule (Vercel Cron, or an external cron
# every minute). CRON_SECRET protects the endpoint (sent as Bearer token).
# ---------------------------------------------------------------------------
# BLOB_TTL_MINUTES="60"
# CRON_SECRET=""

# ---------------------------------------------------------------------------
# AI image generation (preview of the product in the room)
# Provider: "mock" (default) | "openai" | "gemini"
#   mock   -> returns the original room photo with an "AI preview placeholder" label
#   openai -> OpenAI Images edit API (default model gpt-image-1)
#   gemini -> Gemini image model (default gemini-2.5-flash-image)
# Falls back to mock automatically if the matching API key is missing.
# ---------------------------------------------------------------------------
IMAGE_GENERATION_PROVIDER="mock"

# ---------------------------------------------------------------------------
# AI vision dimension estimation (guess W/H/D and available space from a photo)
# Provider: "mock" (default) | "openai" | "gemini"
#   mock   -> heuristic estimate from typical category sizes (no API key)
#   openai -> GPT vision (default model gpt-4o-mini)
#   gemini -> Gemini vision (default gemini-2.0-flash)
# Falls back to mock automatically if the matching API key is missing.
# ---------------------------------------------------------------------------
VISION_PROVIDER="mock"

# ---------------------------------------------------------------------------
# API keys + optional model overrides (shared by image gen and vision)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# Optional model overrides (sensible defaults are used if unset):
# OPENAI_IMAGE_MODEL="gpt-image-1"
# OPENAI_VISION_MODEL="gpt-4o-mini"
# GEMINI_IMAGE_MODEL="gemini-2.5-flash-image"
# GEMINI_VISION_MODEL="gemini-2.0-flash"
